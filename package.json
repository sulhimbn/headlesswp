{
  "name": "headlesswp",
  "version": "1.0.0",
  "description": "WordPress Headless untuk mitrabantennews.com",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "analyze": "ANALYZE=true next build",
    "test": "jest",
    "test:watch": "jest --watch",
    "audit:security": "npm audit --audit-level=moderate",
    "audit:full": "npm audit --audit-level=low",
    "deps:check": "npm outdated",
    "deps:update": "npm update",
    "size-check": "node scripts/bundle-size-check.js",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.40.0",
    "axios": "^1.13.5",
    "isomorphic-dompurify": "^2.36.0",
    "next": "^16.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@size-limit/file": "^12.0.0",
    "@size-limit/preset-app": "^12.0.0",
    "@size-limit/webpack": "^12.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.53.1",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^10.0.2",
    "jest": "^30.2.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "size-limit": "^12.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "wordpress",
    "headless",
    "nextjs",
    "react",
    "rest-api"
  ],
  "author": "Mitra Banten News",
  "license": "MIT",
  "overrides": {
    "js-yaml": "^4.1.1",
    "caniuse-lite": "^1.0.30001774",
    "baseline-browser-mapping": "^2.10.0",
    "serialize-javascript": "^7.0.3"
  }
}
