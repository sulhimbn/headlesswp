# Environment Variables
# Production: Use HTTPS URLs (recommended)
# Local Development: Use http://localhost:8080
WORDPRESS_URL=https://your-domain.com
WORDPRESS_API_URL=https://your-domain.com/wp-json
NEXT_PUBLIC_WORDPRESS_URL=https://your-domain.com
NEXT_PUBLIC_WORDPRESS_API_URL=https://your-domain.com/wp-json

# Site URL Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL_WWW=https://www.your-domain.com

# Note: This application uses WordPress REST API only
# GraphQL dependencies have been removed for better performance

# Authentication (if required)
WP_USERNAME=your_wp_username
WP_PASSWORD=your_wp_application_password

# WordPress Authentication Keys and Salts (CRITICAL for production security)
# Generate secure keys using: https://api.wordpress.org/secret-key/1.1/salt/
# These keys should be unique for each installation
# Do not use the placeholder values below in production!
WP_AUTH_KEY=
WP_SECURE_AUTH_KEY=
WP_LOGGED_IN_KEY=
WP_NONCE_KEY=
WP_AUTH_SALT=
WP_SECURE_AUTH_SALT=
WP_LOGGED_IN_SALT=
WP_NONCE_SALT=

# Build Configuration
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=your_secure_mysql_password_here
MYSQL_ROOT_PASSWORD=your_secure_root_password_here

# WordPress Installation (for install-wordpress.sh)
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=your_secure_admin_password_here
WP_ADMIN_EMAIL=admin@example.com

# Development
NODE_ENV=development

# WordPress Debug (WARNING: Disable in production!)
WP_DEBUG=false
WP_DEBUG_LOG=false
WP_DEBUG_DISPLAY=false

# Build Configuration
# Set to 'true' during CI/build when WordPress backend is not available
# This skips API retry delays during static generation
SKIP_RETRIES=false

# Security Configuration
# CSP Report Endpoint (optional)
NEXT_PUBLIC_CSP_REPORT_ENDPOINT=/api/csp-report

# Security Headers Configuration
SECURITY_HEADERS_ENABLED=true
CSP_ENABLED=true

# Sentry Error Tracking (Optional - leave empty to disable)
# Get your DSN from: https://sentry.io/settings/
SENTRY_DSN=
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
NEXT_PUBLIC_SENTRY_DSN=